# Replace tes-treats.example.com with your real domain.
# Caddy automatically obtains and renews a Let's Encrypt cert.
tes-treats.example.com {
  encode gzip zstd
  reverse_proxy app:3000

  # Stripe webhook MUST receive the raw body. Caddy forwards bodies untouched
  # by default — this matcher is just here as a comment + protection if anyone
  # later adds body-rewriting middleware in front of the proxy.
  @webhooks {
    path /api/webhooks/*
  }
  reverse_proxy @webhooks app:3000

  # Cache static assets aggressively.
  @static {
    path /_next/static/*
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
}
