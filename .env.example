# Copy to .env.local for local dev. Production values live in DO App Platform
# env vars (set via `doctl apps update` or the dashboard) — never commit real keys.

# Database
DATABASE_URL=postgres://tes:tes@localhost:5432/tes_treats

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-locally
AUTH_URL=http://localhost:3000
# Comma-separated emails. Anyone with a matching email becomes role=admin on
# first sign-in (no SQL needed). Add your own here for local admin work.
ADMIN_EMAILS=

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth 2.0)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (SMTP — works with Mailpit dev catcher, Resend, SES, Postmark, etc.)
# Local dev defaults below talk to the Mailpit container on :1025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="TES Treats <hi@tes-treats.example>"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# DigitalOcean Spaces (S3-compatible) for product + custom-request photo uploads
# https://cloud.digitalocean.com/spaces
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=tes-treats-uploads
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_PUBLIC_BASE=https://tes-treats-uploads.nyc3.cdn.digitaloceanspaces.com
